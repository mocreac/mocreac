{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "routes": [
    {
      "src": "/calendar",
      "dest": "https://mocalendar.vercel.app/calendar/"
    },
    {
      "src": "/calendar/(.*)",
      "dest": "https://mocalendar.vercel.app/calendar/$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
